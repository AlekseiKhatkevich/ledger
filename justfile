#!/usr/bin/env just --justfile

set dotenv-filename := "secrets/just/.env"

default: up-dev

alias up := up-dev
alias down := down-dev

default_alembic_upgrade_target := 'head'
default_alembic_downgrade_target := '-1'

#  start container
up-dev:
    docker compose  up --watch --remove-orphans

#  stop container
down-dev:
    docker compose down

#  build container
build:
    docker compose build

#  make alemic autogenerated migration. just makemigrations {{message}}
makemigrations message:
    uv run alembic revision --autogenerate -m "{{message}}"

# push alembic migration into db
migrate where=default_alembic_upgrade_target:
    uv run alembic upgrade {{where}}

# remove last migration from db
downgrade where=default_alembic_downgrade_target:
    uv run alembic downgrade {{where}}